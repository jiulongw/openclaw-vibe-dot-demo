{
  "name": "@openclaw/vibedot-demo",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw channel plugin for Vibe Dot meeting transcriptions (demo)",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "vibedot",
      "label": "Vibe Dot",
      "selectionLabel": "Vibe Dot (SSE transcription)",
      "detailLabel": "Vibe Dot",
      "blurb": "One-way channel for Vibe Dot meeting transcriptions via SSE.",
      "order": 100,
      "markdownCapable": false
    }
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run format:check && tsc --noEmit"
  },
  "devDependencies": {
    "openclaw": "^2026.4.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
