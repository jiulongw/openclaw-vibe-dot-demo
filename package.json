{
  "name": "openclaw-vibedot-plugin",
  "version": "0.0.1",
  "private": true,
  "description": "OpenClaw channel plugin for Vibe Dot transcriptions and commands",
  "type": "module",
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.1"
    },
    "build": {
      "openclawVersion": ">=2026.1"
    },
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "vibedot",
      "label": "Vibe Dot",
      "selectionLabel": "Vibe Dot",
      "detailLabel": "Vibe Dot",
      "blurb": "One-way channel for Vibe Dot transcriptions and commands via SSE.",
      "order": 100,
      "markdownCapable": false
    }
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run format:check && tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "openclaw": "^2026.4.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
